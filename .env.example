# Dev: use /api (Vite proxies to backend — see vite.config.ts)
VITE_API_BASE_URL=/api

# Production: point to your live API
# VITE_API_BASE_URL=https://api.yourdomain.com/api

# Dev proxy target (vite.config.ts only — not needed in production build)
# VITE_PROXY_TARGET=http://192.168.1.45:8000

VITE_USER_ID=123456
VITE_SPACE_ID=123456
